#!/usr/bin/env python3

import argparse
import os
import sys
from typing import Sequence

import requests

DEFAULT_SERVER = os.environ.get('NTFY_SERVER', 'http://ntfy.home')

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog = os.path.basename(__file__)
    )

    parser.add_argument('topic')
    parser.add_argument('-s', '--server', default = DEFAULT_SERVER)
    parser.add_argument('-t', '--title', default = '*')
    parser.add_argument('-m', '--message', default = '-')
    parser.add_argument('-p', '--priority', default = 'default', choices = [ 'max', 'high', 'default', 'low', 'min' ])
    parser.add_argument('-T', '--tags', nargs = '+', default = [])
    parser.add_argument('-v', '--verbose', action = 'store_true')

    return parser.parse_args()

def post(server: str, topic: str, title: str, message: str, priority: str, tags: Sequence[str]) -> requests.Response:
    response = requests.post(
        url = f'{server}/{topic}',
        data = message,
        headers = {
            'Title': title,
            'Priority': priority,
            'Tags': ','.join(tags),
        },
        timeout = 10,
    )

    response.raise_for_status()

    return response

def main() -> None:
    args = parse_args()

    message = sys.stdin.read() if args.message == '-' else args.message

    response = post(
        server = args.server,
        topic = args.topic,
        title = args.title,
        message = message,
        priority = args.priority,
        tags = args.tags,
    )

    if args.verbose:
        sys.stdout.write(f'{response.status_code} {response.text.strip()}\n')

if __name__ == '__main__':
    try:
        main()
    except requests.RequestException as exc:
        sys.stderr.write(f'Error: {exc}\n')
        raise SystemExit(1)
